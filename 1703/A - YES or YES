public class Main {
  public static void main(String[] args) {
    java.util.Scanner sc = new java.util.Scanner(System.in);
    int tc = sc.nextInt();
    for (int t = 0; t < tc; t++) {
      String s = sc.next().toLowerCase();
      if (s.equals("yes")) {
        System.out.println("YES");
      } else {
        System.out.println("NO"); 
      }
    }
    sc.close();
  }
}