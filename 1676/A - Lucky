import java.util.Scanner;
 
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int t = sc.nextInt();
        while (t-- > 0) {
            int n = sc.nextInt();
            // first three digits
            int firstThreeDigits = n / 1000;
            // last three digits
            int lastThreeDigits = n % 1000;
            int sumFirstThreeDigits = 0;
            int sumLastThreeDigits = 0;
            while (firstThreeDigits > 0) {
                sumFirstThreeDigits += firstThreeDigits % 10;
                firstThreeDigits /= 10;
            }
            while (lastThreeDigits > 0) {
                sumLastThreeDigits += lastThreeDigits % 10;
                lastThreeDigits /= 10;
            }
            if (sumFirstThreeDigits == sumLastThreeDigits) {
                System.out.println("YES");
            } else {
                System.out.println("NO");
            }
        }
        sc.close();
    }
}